{
  "name": "n8n-nodes-cortana-ai",
  "version": "0.3.3",
  "description": "Cortana AI community node for n8n — trigger on new conversions/contacts and create conversions with full attribution.",
  "keywords": [
    "n8n-community-node-package",
    "cortana-ai",
    "attribution",
    "conversions",
    "marketing",
    "crm"
  ],
  "license": "MIT",
  "homepage": "https://agentkong.ai",
  "author": {
    "name": "Cortana AI",
    "email": "hello@usecortana.ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentKong/n8n-nodes-cortana-ai"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials",
    "lintfix": "eslint nodes credentials --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/CortanaAiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/CortanaAi/CortanaAi.node.js",
      "dist/nodes/CortanaAi/CortanaAiTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.16.16",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^8.57.1",
    "eslint-plugin-n8n-nodes-base": "^1.16.6",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "typescript": "^5.1.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
